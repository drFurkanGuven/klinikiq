# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://klinikiq:password@postgres:5432/klinikiq

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=change_this_secret_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ─── Farmakoloji (TİTCK proxy) ──────────────────────────
# docker-compose.yml backend servisi, ağ içi adresi kendisi verir: http://titck-medicine-api:3000
# Sadece backend’i Docker’sız çalıştırıyorsan (API ayrı terminalde):
# TURKISH_MEDICINE_API_URL=http://127.0.0.1:3000

# ─── Frontend (Next.js public env) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

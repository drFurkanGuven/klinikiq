# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://klinikiq:password@postgres:5432/klinikiq

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=change_this_secret_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# Acil MCQ veri dosyası (Türkçe: unified_emergency_tr.jsonl)
MEDICAL_QA_EMERGENCY_JSONL=data/medical_qa/emergency/unified_emergency_tr.jsonl

# ─── Farmakoloji (DrugBank + CARD) ─────────────────────
# Veri: python backend/scripts/import_drugbank.py <drugbank_clean.csv>
#       python backend/scripts/import_card.py <aro_index.tsv>

# ─── Frontend (Next.js public env) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
